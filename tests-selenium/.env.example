# CharityAI Selenium E2E Test Environment Variables
# Copy this file to .env and fill in real values for local runs.
# In GitHub Actions, these are set as repository SECRETS.

# ---------------------------------------------------------------
# Frontend base URL (your GitHub Pages deployment)
# Example: https://yourusername.github.io/CharityAI
# ---------------------------------------------------------------
TEST_BASE_URL=https://yourusername.github.io/CharityAI

# ---------------------------------------------------------------
# Backend API URL (your Render deployment)
# ---------------------------------------------------------------
TEST_API_URL=https://charityai-backend.onrender.com/api

# ---------------------------------------------------------------
# Credentials for LOGIN tests (must be a real registered account)
# ---------------------------------------------------------------
TEST_EMAIL=testuser@example.com
TEST_PASSWORD=TestPass@123

# ---------------------------------------------------------------
# Credentials for REGISTER tests (a unique email each run)
# Leave blank — the runner auto-generates a timestamped email.
# ---------------------------------------------------------------
TEST_REGISTER_EMAIL=

# ---------------------------------------------------------------
# Selenium timeout (ms) — increase for slow CI environments
# ---------------------------------------------------------------
SELENIUM_TIMEOUT=30000

# ---------------------------------------------------------------
# Set to "true" to run Chrome in headed mode (for local debugging)
# ---------------------------------------------------------------
HEADED=false
