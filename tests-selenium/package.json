{
  "name": "charityai-e2e-tests",
  "version": "1.0.0",
  "description": "Selenium E2E + Security + API tests for CharityAI web application",
  "main": "run_tests.js",
  "type": "commonjs",
  "scripts": {
    "test": "node run_tests.js",
    "test:func": "node run_tests.js --suite=functionality",
    "test:vuln": "node run_tests.js --suite=vulnerability",
    "test:unit": "node run_tests.js --suite=unit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "chromedriver": "^131.0.3",
    "exceljs": "^4.4.0",
    "selenium-webdriver": "^4.27.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
